        "mode": "runOnceForEachItem",
        "jsCode": "const today = new Date().toISOString().split(\"T\")[0];\nconst itemDate = item.timestamp ? item.timestamp.split(\" \")[0] : \"\";\n\nif (itemDate === today) {\n  return item;\n} else {\n  return null;\n}"
      },
