      "id": "3be49a83-d950-4424-bc3d-baf7f2137792",
      "name": "[IREM] Analyze with Gemini",
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1.1,
      "position": [
        688,
        496
      ],
      "credentials": {
        "googlePalmApi": {
          "id": "xAc3QI3gii34OtcS",
          "name": "Google Gemini(PaLM) Api account"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "try {\n  const content = item.message?.content || item.content || JSON.stringify(item);\n  const parsed = JSON.parse(content);\n  \n  const validSentiments = [\"positive\", \"neutral\", \"negative\"];\n  const validSatisfaction = [\"high\", \"medium\", \"low\"];\n  const validWaste = [\"yes\", \"no\"];\n  const validIssues = [\"taste\", \"portion\", \"speed\", \"availability\", \"none\", \"other\"];\n  const validDemand = [\"more_of_this_meal\", \"less_of_this_meal\", \"no_clear_signal\"];\n  const validIntent = [\"high\", \"medium\", \"low\"];\n  \n  if (!validSentiments.includes(parsed.sentiment) ||\n      !validSatisfaction.includes(parsed.satisfaction_level) ||\n      !validWaste.includes(parsed.waste_signal) ||\n      !validIssues.includes(parsed.main_issue) ||\n      !validDemand.includes(parsed.demand_signal) ||\n      !validIntent.includes(parsed.revisit_intent) ||\n      !parsed.short_summary) {\n    return { ...item, parse_error: true, error_reason: \"Invalid field values\" };\n  }\n  \n  return {\n    ...item,\n    sentiment: parsed.sentiment,\n    satisfaction_level: parsed.satisfaction_level,\n    waste_signal: parsed.waste_signal,\n    main_issue: parsed.main_issue,\n    demand_signal: parsed.demand_signal,\n    revisit_intent: parsed.revisit_intent,\n    short_summary: parsed.short_summary,\n    parse_error: false\n  };\n} catch (error) {\n  return { ...item, parse_error: true, error_reason: error.message };\n}"
      },
