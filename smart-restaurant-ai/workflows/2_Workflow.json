        "jsCode": "const summary = ($json.short_summary || \"\").toLowerCase();\nconst comment = ($json.open_comment || \"\").toLowerCase();\nconst combinedText = summary + \" \" + comment;\n\nconst highUrgencyKeywords = [\n  \"hijyen\", \"kirli\", \"pis\", \"böcek\", \"saç\", \"zehir\",\n  \"hasta\", \"kusma\", \"mide\", \"iğrenç\", \"berbat\",\n  \"asla\", \"kesinlikle\", \"hiç\", \"rezalet\"\n];\n\nconst isHighUrgency =\n  highUrgencyKeywords.some(keyword => combinedText.includes(keyword)) ||\n  ($json.satisfaction_level === \"low\" && $json.sentiment === \"negative\");\n\nreturn {\n  ...$json,\n  urgency_level: isHighUrgency ? \"high\" : \"medium\"\n};"
