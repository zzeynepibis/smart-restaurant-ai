      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "1",
              "name": "ai_prompt",
              "value": "=Analyze this restaurant feedback and return ONLY a valid JSON object with these exact fields:\n\nsentiment (positive/neutral/negative)\nsatisfaction_level (high/medium/low)\nwaste_signal (yes/no) - yes if portion too large, food left over, or meal unwanted\nmain_issue (taste/portion/speed/availability/none/other)\ndemand_signal (more_of_this_meal/less_of_this_meal/no_clear_signal)\nrevisit_intent (high/medium/low)\nshort_summary (one short Turkish sentence)\n\nFeedback data:\nSelected meals: {{ $json.selected_meals }}\nTaste score: {{ $json.taste_score }}/5\nPortion feedback: {{ $json.portion_feedback }}\nLeftover amount: {{ $json.leftover_amount }}\nMissing meal: {{ $json.missing_meal }}\nRecommend score: {{ $json.recommend_score }}/10\nOpen comment: {{ $json.open_comment }}\n\nReturn ONLY the JSON object, no other text.",
              "type": "string"
            }
          ]
        },
        "includeOtherFields": true,
        "options": {}
      },
      "id": "45d119e5-9a31-42cf-8870-4dd1942ec1e8",
      "name": "[IREM] Prepare AI Input",
      "type": "n8n-nodes-base.set",
